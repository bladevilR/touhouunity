"casual":[
{"l":[["本居小铃","铃奈庵的书种类很多。外界书妖魔书历史书都有。不过有些人说妖魔书不该放在店里。","neutral"]],"c":"bond_min:1"},
{"l":[["本居小铃","我能解读任何文字。连妖魔书也能读。这个能力有时候让我能看到不该看的东西。","neutral"]],"c":"bond_min:2"},
{"l":[["本居小铃","阿求是我的好朋友。她经常来借书。不过她借走都不还——说是在'参考资料'。","happy"]],"c":"bond_min:3"},
{"l":[["本居小铃","有时候读到太可怕的书晚上不敢睡觉。然后灵梦就会过来说'叫你别看那么多妖魔书了'。","sad"]],"c":"bond_min:4"},
{"l":[["本居小铃","妹红前辈活得这么久...您觉得书里的历史和真实的历史哪个更准确？","neutral"]],"c":"bond_min:5"}
],
"annoyed":[
{"l":[["本居小铃","又来看书啦？今天想找什么题材？","happy"]],"c":"talk_count_min:3,talk_count_max:4"},
{"l":[["本居小铃","妹红前辈今天来得好勤。是不是在找什么特别的书？我帮您！","happy"]],"c":"talk_count_min:5,bond_min:3"}
],
"gossip":[
{"l":[["本居小铃","魔理沙来借书从来不走正门。总是从窗户飞进来然后说'我只是看看'。","angry"]],"c":"bond_min:2"},
{"l":[["本居小铃","阿求说想写一本关于铃奈庵的书。我说好啊——但是不要把我害怕妖魔书的事情写进去。","happy"]],"c":"bond_min:3"}
],
